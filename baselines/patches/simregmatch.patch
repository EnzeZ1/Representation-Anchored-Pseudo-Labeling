 def conv3x3(in_planes, out_planes, stride=1):
@@ -128,5 +130,12 @@ class ResNet(nn.Module):
         return x, encoding
 
 
-def resnet50(dropout):
-    return ResNet(Bottleneck, [3, 4, 6, 3], dropout)
+def resnet50(dropout, pretrained=False):
+    model = ResNet(Bottleneck, [3, 4, 6, 3], dropout)
+    if pretrained:
+        state = load_state_dict_from_url(ResNet50_Weights.IMAGENET1K_V1.url, progress=True)
+        state = {key: value for key, value in state.items() if not key.startswith('fc.')}
+        incompatible = model.load_state_dict(state, strict=False)
+        assert set(incompatible.missing_keys) == {'linear.weight', 'linear.bias'}
+        assert not incompatible.unexpected_keys
+    return model
