diff --git a/semilearn/core/utils/misc.py b/semilearn/core/utils/misc.py
index 39beaed..38000b4 100644
--- a/semilearn/core/utils/misc.py
+++ b/semilearn/core/utils/misc.py
@@ -206,3 +206,15 @@ class TorchMinMaxScaler:
         tensor.sub_(self._output_min).div_(self._output_scale)
         tensor.mul_(self._input_scale).add_(self._input_min)
         return tensor
+
+
+class TorchStandardScaler:
+    def __init__(self, mean, std):
+        self.mean = float(mean)
+        self.std = float(std)
+
+    def transform(self, tensor):
+        return tensor.sub_(self.mean).div_(self.std)
+
+    def inverse_transform(self, tensor):
+        return tensor.mul_(self.std).add_(self.mean)
