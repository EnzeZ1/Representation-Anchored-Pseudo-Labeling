cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Environments
.venv/
venv/
env/

# Data and checkpoints
data/
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors

# Experiment tracking
wandb/
runs/
lightning_logs/

# Secrets
.env
.env.*
*.pem
*.key

# Large generated files
*.npy
*.npz

# Third-party repository, handle separately
Heteroscedastic-Pseudo-Labels-main/
EOF